{
  "database": {
    "description": "数据库与存储机制",
    "type": "object",
    "hint": "选择历史消息使用的底层数据库类型并配置其连接参数",
    "items": {
      "db_type": {
        "description": "数据库类型",
        "type": "string",
        "default": "sqlite",
        "options": [
          "sqlite",
          "mysql"
        ],
        "hint": "推荐使用开箱即用的 SQLite。如果有性能或集群需求，可选择配置 MySQL"
      },
      "sqlite_db_path": {
        "description": "[SQLite] 数据库存储路径",
        "type": "string",
        "default": "data/plugin_data/astrbot_plugin_sql_history/sqlite/data_v1.db",
        "hint": "SQLite 数据库文件的具体保存位置"
      },
      "host": {
        "description": "[MySQL] 主机地址",
        "type": "string",
        "hint": "MySQL服务器地址，如 127.0.0.1"
      },
      "port": {
        "description": "[MySQL] 端口号",
        "type": "int",
        "default": 3306
      },
      "database": {
        "description": "[MySQL] 数据库名",
        "type": "string"
      },
      "username": {
        "description": "[MySQL] 用户名",
        "type": "string"
      },
      "password": {
        "description": "[MySQL] 密码",
        "type": "string"
      }
    }
  },
  "image": {
    "description": "图片资源设置",
    "type": "object",
    "hint": "开启后，所有的聊天图片将被下载并备份。注意：这会占用磁盘存储空间",
    "items": {
      "is_save_image": {
        "description": "开启图片本地持久化",
        "type": "bool",
        "default": false,
        "hint": "是否将聊天图片缓存至硬盘长期保存"
      },
      "image_save_path": {
        "description": "图片归档总目录",
        "type": "string",
        "default": "data/plugin_data/astrbot_plugin_sql_history/image",
        "hint": "建议存放在 data/plugin_data 目录下防止丢失，插件将会自动基于此目录创建并持久化文件"
      },
      "storage_mode": {
        "description": "图像存储模式",
        "type": "string",
        "default": "local",
        "options": [
          "local",
          "cloudflare",
          "both"
        ],
        "hint": "选择图片存储方式：本地存储(local) / CloudFlare ImgBed图床(cloudflare) / 同时存储到两者(both)"
      },
      "auto_reupload_old": {
        "description": "自动补传旧图",
        "type": "bool",
        "default": true,
        "hint": "检测到数据库中已存在但未上传到CF的旧图时，是否自动补传。开启后切换存储模式时，新消息中遇到的旧图会自动补传到图床"
      },
      "cf_api_endpoint": {
        "description": "[CloudFlare] API端点地址",
        "type": "string",
        "default": "",
        "hint": "CloudFlare ImgBed 服务的完整地址，例如 https://img.example.com"
      },
      "cf_api_token": {
        "description": "[CloudFlare] API Token",
        "type": "string",
        "default": "",
        "hint": "CloudFlare ImgBed 生成的 API Token，需要 upload 权限"
      },
      "cf_channel_mode": {
        "description": "[CloudFlare] 渠道选择模式",
        "type": "string",
        "default": "manual",
        "options": [
          "manual",
          "auto"
        ],
        "hint": "manual: 手动指定上传渠道；auto: 自动从/api/channels获取可用渠道，轮询负载均衡"
      },
      "cf_upload_channel": {
        "description": "[CloudFlare] 手动指定上传渠道",
        "type": "string",
        "default": "telegram",
        "hint": "存储渠道：telegram、cfr2、s3、discord、huggingface。channel_mode=manual 时生效"
      },
      "cf_server_compress": {
        "description": "[CloudFlare] 服务端压缩",
        "type": "bool",
        "default": true,
        "hint": "是否开启服务端图片压缩"
      },
      "cf_return_full_url": {
        "description": "[CloudFlare] 返回完整URL",
        "type": "bool",
        "default": true,
        "hint": "是否返回完整的图片URL（否则只返回路径部分）"
      },
      "cf_upload_folder": {
        "description": "[CloudFlare] 上传目录",
        "type": "string",
        "default": "QQ",
        "hint": "上传到图床的哪个目录，使用相对路径，例如 QQ、images/chat。留空表示上传到根目录"
      }
    }
  },
  "advanced": {
    "description": "高级选项",
    "type": "object",
    "hint": "插件整体高级调试和 troubleshooting 配置",
    "items": {
      "debug_log": {
        "description": "开启调试日志",
        "type": "bool",
        "default": false,
        "hint": "开启后输出更多调试日志，方便排查问题"
      }
    }
  }
}